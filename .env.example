# === Database ===
DATABASE_URL=postgresql+asyncpg://doce_erp:changeme@localhost:5432/doce_erp
POSTGRES_USER=doce_erp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=doce_erp

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0

# === Auth ===
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === LDAP ===
LDAP_URL=ldap://your-ldap-server:389
LDAP_BIND_DN=cn=admin,dc=siliconmotion,dc=com
LDAP_BIND_PASSWORD=changeme
LDAP_BASE_DN=dc=siliconmotion,dc=com
LDAP_USER_SEARCH_FILTER=(uid={username})

# === LLM / AI ===
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
LLM_CONTEXT_MAX_TOKENS=4096

# === Git Backend ===
GIT_BACKEND_TYPE=github
GERRIT_URL=http://your-gerrit:8080
GITHUB_TOKEN=ghp_your_github_token
GITLAB_URL=https://gitlab.siliconmotion.com
GITLAB_TOKEN=glpat_your_gitlab_token

# === Email (SMTP) ===
SMTP_HOST=smtp.siliconmotion.com
SMTP_PORT=587
SMTP_USER=doce-erp@siliconmotion.com
SMTP_PASSWORD=changeme
SMTP_FROM=doce-erp@siliconmotion.com

# === Storage ===
AUDIT_PACKAGE_STORAGE_PATH=/app/storage/audit_packages
AUDIT_PACKAGE_QUOTA_WARNING_GB=50

# === CodeBeamer ===
CODEBEAMER_SCHEMA_VERSION=v2024.1
